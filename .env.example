# Meridian — optional live-data & AI keys (TEMPLATE — placeholders only, no secrets).
#
# Everything here is OPTIONAL. The app runs fully on the deterministic, seeded core
# with none of these set. Copy this file to `.env.local` and fill in the ones you want.
# `.env.local` is gitignored and must NEVER be committed.

# ── Live data (server-side, free-signup keys) ─────────────────────────────────
# EIA petroleum prices        → https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# AISStream vessel positions  → https://aisstream.io/  (free WebSocket key)
AISSTREAM_API_KEY=

# ── Live AI (optional) ────────────────────────────────────────────────────────
# Google Gemini — free key at https://aistudio.google.com/apikey
# ⚠️  LOCAL DEV ONLY. Do NOT set this in Vercel/production: as a NEXT_PUBLIC_* var it is
#     inlined into the browser bundle. In production use the in-app "Connect AI" dialog,
#     which keeps the key in the browser's localStorage only.
NEXT_PUBLIC_GEMINI_API_KEY=

# ── Deploy ────────────────────────────────────────────────────────────────────
# Base path if hosting under a sub-path (e.g. GitHub Pages "/meridian").
# Leave blank for Vercel (served at the domain root).
NEXT_PUBLIC_BASE_PATH=
